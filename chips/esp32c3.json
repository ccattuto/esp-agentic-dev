{
  "name": "ESP32-C3",
  "arch": "riscv32",
  "svd": "chips/esp32c3.svd",
  "memory": {
    "flash_dbus": {
      "start": "0x3C000000",
      "size": "0x800000",
      "description": "Flash (data bus, memory-mapped, read-only)"
    },
    "sram_dbus": {
      "start": "0x3FC80000",
      "size": "0x60000",
      "description": "Internal DIRAM SRAM (data bus)"
    },
    "rom_dbus": {
      "start": "0x3FF00000",
      "size": "0x20000",
      "description": "Internal ROM (data bus, read-only)"
    },
    "rom_ibus": {
      "start": "0x40000000",
      "size": "0x60000",
      "description": "Internal ROM (instruction bus, read-only)"
    },
    "sram_ibus": {
      "start": "0x4037C000",
      "size": "0x64000",
      "description": "Internal DIRAM SRAM (instruction bus alias)"
    },
    "flash_ibus": {
      "start": "0x42000000",
      "size": "0x800000",
      "description": "Flash (instruction bus, memory-mapped, read-only)"
    },
    "rtc": {
      "start": "0x50000000",
      "size": "0x2000",
      "description": "RTC Fast Memory (data/instruction bus)"
    },
    "peripherals": {
      "start": "0x60000000",
      "size": "0xD1000",
      "description": "Peripheral registers"
    }
  }
}
